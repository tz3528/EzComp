declarations {
    t[0,100,101];
    x[0,100,101];
}
equations {
    diff(u(t,x),t,1)=100*diff(u(t,x),x,2);
    diff(u(t,x),x,2)=(u(t,x-1)+u(t,x+1)-2*u(t,x))/delta(x,2);
    u(t+1,x) = u(t,x) + diff(u(t,x),t,1) * delta(x,1);
    u(0,x)=0;
    u(t,0)=10;
    u(t,100)=10;
}
options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(t,x)";
    timeVar:"t";
}

