#===-- 1d_boundary_with_time.test -----------------------------*-- Comp -*-===#
#
# 1D: 边界方程右侧有时间信息 - AffineToSCF 测试
# 验证 sin 函数被正确降级为 math.sin
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true})" | FileCheck %s

# ===== 确保没有 affine.for =====
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 初始化循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}101{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 边界条件循环1：u(0,t) = sin(t) =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: math.sin {{.*}} : f64
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 边界条件循环2：u(100,t) =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主迭代循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}50{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}101{{.*}} step {{.*}}
# CHECK: memref.load {{.*}} : memref<2x101xf64>
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主循环内的边界条件循环（包含 sin）=====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: math.sin {{.*}} : f64
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: return

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = 0;
    u(0,t) = sin(t);
    u(100,t) = 0;
    u(x,t+1) = u(x,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}
