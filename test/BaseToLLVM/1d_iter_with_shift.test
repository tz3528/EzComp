#===-- 1d_iter_with_shift.test --------------------------------*-- Comp -*-===#
#
# 1D: 迭代方程右侧有位置偏移 - BaseToLLVM 测试
# u(x,t+1) = u(x-1,t) + u(x+1,t) → 验证偏移索引计算
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true base-llvm=true})" | FileCheck %s

# ===== 验证 LLVM 函数入口 =====
# CHECK-LABEL: llvm.func @main()

# ===== 验证常量（函数开头）=====
# CHECK: llvm.mlir.constant

# ===== 验证内存分配（malloc）=====
# CHECK: llvm.call @malloc

# ===== 验证控制流操作 =====
# CHECK: llvm.br
# CHECK: llvm.cond_br

# ===== 验证比较操作 =====
# CHECK: llvm.icmp "slt"

# ===== 验证多个内存加载（带偏移）=====
# CHECK-DAG: llvm.load
# CHECK-DAG: llvm.load

# ===== 验证浮点加法 =====
# CHECK: llvm.fadd

# ===== 验证内存存储 =====
# CHECK: llvm.store

# ===== 验证返回 =====
# CHECK: llvm.return

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = 0;
    u(0,t) = 0;
    u(100,t) = 0;
    u(x,t+1) = u(x-1,t) + u(x+1,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}
