#===-- 1d_iter_single.test ------------------------------------*-- Comp -*-===#
#
# 1D: 单个迭代方程 - CompToBase 测试
# u(x,t+1) = u(x,t) → 单个 sample，无空间偏移
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证 memref 分配：第一维=2，第二维=x.points=101 =====
# CHECK: memref.alloc() : memref<2x101xf64>

# ===== 初始化循环 =====
# CHECK: affine.for {{.*}} = 0 to 101
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 边界条件循环 =====
# CHECK: affine.for {{.*}} = 0 to 51
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: affine.for {{.*}} = 0 to 51
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 时间迭代循环：t (0 to 50) =====
# CHECK: affine.for {{.*}} = 0 to 50

# ===== 空间更新循环：无偏移，完整遍历 x (0 to 101) =====
# CHECK: affine.for {{.*}} = 0 to 101

# ===== 验证 memref 加载和存储 =====
# CHECK: memref.load {{.*}} : memref<2x101xf64>
# CHECK: memref.store {{.*}} : memref<2x101xf64>

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = 0;
    u(0,t) = 0;
    u(100,t) = 0;
    u(x,t+1) = u(x,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}