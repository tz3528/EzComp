#===-- 2d_boundary_with_time.test -----------------------------*-- Comp -*-===#
#
# 2D: 边界方程右侧有时间信息 - CompToBase 测试
# u(0,y,t) = sin(t) → 边界条件依赖时间，降级为 math.sin
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证 memref 分配：第一维=2，后续=x.points=11, y.points=11 =====
# CHECK: memref.alloc() : memref<2x11x11xf64>

# ===== 初始化循环 =====
# CHECK: affine.for {{.*}} = 0 to 11
# CHECK: affine.for {{.*}} = 0 to 11
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 边界条件循环1：u(0,y,t) = sin(t) =====
# CHECK: affine.for {{.*}} = 0 to 11
# CHECK: affine.for {{.*}} = 0 to 11
# CHECK: math.sin
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 时间迭代循环 =====
# CHECK: affine.for {{.*}} = 0 to 10
# CHECK: affine.for {{.*}} = 0 to 11
# CHECK: affine.for {{.*}} = 0 to 11
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = sin(t);
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    u(x,y,t+1) = u(x,y,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}