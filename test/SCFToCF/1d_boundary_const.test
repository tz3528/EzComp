#===-- 1d_boundary_const.test ---------------------------------*-- Comp -*-===#
#
# 1D: 边界方程右侧为常数 - SCFToCF 测试
# 验证所有 scf.for 被正确降级为 cf.br / cf.cond_br 控制流
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true scf-cf=true})" | FileCheck %s

# ===== 确保没有 scf.for 和 affine.for =====
# CHECK-NOT: scf.for
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x101xf64>

# ===== 初始化循环：遍历 x =====
# CHECK: cf.br {{.*}}(%c0 : index)
# CHECK: arith.cmpi slt, {{.*}}, %c101 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 边界条件循环1：u(0,t) = 10 =====
# CHECK: arith.cmpi slt, {{.*}}, %c51 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 边界条件循环2：u(100,t) =====
# CHECK: arith.cmpi slt, {{.*}}, %c51 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主迭代循环：遍历 t =====
# CHECK: arith.cmpi slt, {{.*}}, %c50 : index
# CHECK: cf.cond_br

# ===== 内层迭代循环：遍历 x =====
# CHECK: arith.cmpi slt, {{.*}}, %c101 : index
# CHECK: cf.cond_br
# CHECK: memref.load {{.*}} : memref<2x101xf64>
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主循环内的边界条件循环（包含常量 10）=====
# CHECK: arith.cmpi slt, {{.*}}, %c51 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c51 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: return

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = 0;
    u(0,t) = 10;
    u(100,t) = 0;
    u(x,t+1) = u(x,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}
