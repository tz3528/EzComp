#===-- 2d_iter_multi.test -------------------------------------*-- Comp -*-===#
#
# 2D: 多个迭代方程 - SCFToCF 测试
# 验证所有 scf.for 被正确降级为 cf.br / cf.cond_br 控制流
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true scf-cf=true})" | FileCheck %s

# ===== 确保没有 scf.for 和 affine.for =====
# CHECK-NOT: scf.for
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x11x11xf64>

# ===== 初始化循环 =====
# CHECK: cf.br {{.*}}(%c0 : index)
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 边界条件循环 =====
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 主迭代循环 =====
# CHECK: arith.cmpi slt, {{.*}}, %c10 : index
# CHECK: cf.cond_br

# ===== 内层循环 x (1 to 10) =====
# CHECK: arith.cmpi slt, {{.*}}, %c10 : index
# CHECK: cf.cond_br

# ===== 最内层循环 y =====
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: arith.addf
# CHECK: arith.subf
# CHECK: arith.divf
# CHECK: arith.addf
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 主循环内的边界条件循环 =====
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: return

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = 0;
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    diff(u(x,y,t),x,2) = (u(x-1,y,t)+u(x+1,y,t)-2*u(x,y,t))/delta(x,2);
    u(x,y,t+1) = u(x,y,t) + diff(u(x,y,t),x,2);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}
