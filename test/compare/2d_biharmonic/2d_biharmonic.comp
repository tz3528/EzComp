# 2D 双调和方程（四阶扩散）
# 方程: ∂u/∂t = -D·∇⁴u
# 其中 ∇⁴u = ∂⁴u/∂x⁴ + 2·∂⁴u/∂x²∂y² + ∂⁴u/∂y⁴
# 模板: 13点（包含对角邻居）
# 描述: 模拟薄膜振动、薄板弯曲等四阶扩散过程

declarations {
    t[0,250,501];
    x[0,2000,2001];
    y[0,2000,2001];
}

equations {
    # 四阶扩散系数
    D = 1e-6;

    # x方向四阶导数 (5点模板)
    d4x = (u(t,x-2,y) - 4*u(t,x-1,y) + 6*u(t,x,y) - 4*u(t,x+1,y) + u(t,x+2,y)) / delta(x,4);

    # y方向四阶导数 (5点模板)
    d4y = (u(t,x,y-2) - 4*u(t,x,y-1) + 6*u(t,x,y) - 4*u(t,x,y+1) + u(t,x,y+2)) / delta(y,4);

    # 混合四阶导数
    d4xy = (u(t,x+1,y+1) + u(t,x+1,y-1) + u(t,x-1,y+1) + u(t,x-1,y-1)
            - 2*(u(t,x+1,y) + u(t,x-1,y) + u(t,x,y+1) + u(t,x,y-1))
            + 4*u(t,x,y)) / (delta(x,2) * delta(y,2));

    # 完整双调和算子
    bilaplacian = d4x + 2*d4xy + d4y;

    # 时间推进：显式欧拉
    u(t+1,x,y) = u(t,x,y) - D * bilaplacian * delta(t,1);

    # 初始条件：中心高斯分布
    u(0,x,y) = 100*exp(-((x-500)*(x-500)+(y-500)*(y-500))/5000);

    # 边界条件（四阶方程需要两层边界）
    # 左边界 (x=0, x=1)
    u(t,0,y) = 0;
    u(t,1,y) = 0;
    # 右边界 (x=1000, x=999)
    u(t,1000,y) = 0;
    u(t,999,y) = 0;
    # 下边界 (y=0, y=1)
    u(t,x,0) = 0;
    u(t,x,1) = 0;
    # 上边界 (y=1000, y=999)
    u(t,x,1000) = 0;
    u(t,x,999) = 0;
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(t,x,y)";
    timeVar:"t";
}
