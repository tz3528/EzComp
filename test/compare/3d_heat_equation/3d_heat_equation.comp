# 3D热传导方程 - 基础示例
# 方程: ∂u/∂t = α * (∂²u/∂x² + ∂²u/∂y² + ∂²u/∂z²)
# 描述: 模拟三维立方体中的热传导

declarations {
    t[0,100,101];
    x[0,400,401];
    y[0,400,401];
    z[0,400,401];
}

equations {
    # 热传导方程（热扩散系数 α=0.15）
    diff(u(t,x,y,z),t,1)=0.15*(diff(u(t,x,y,z),x,2)+diff(u(t,x,y,z),y,2)+diff(u(t,x,y,z),z,2));

    # x方向二阶空间导数
    diff(u(t,x,y,z),x,2)=(u(t,x-1,y,z)+u(t,x+1,y,z)-2*u(t,x,y,z))/delta(x,2);

    # y方向二阶空间导数
    diff(u(t,x,y,z),y,2)=(u(t,x,y-1,z)+u(t,x,y+1,z)-2*u(t,x,y,z))/delta(y,2);

    # z方向二阶空间导数
    diff(u(t,x,y,z),z,2)=(u(t,x,y,z-1)+u(t,x,y,z+1)-2*u(t,x,y,z))/delta(z,2);

    # 从时间导数更新到下一时间步
    u(t+1,x,y,z) = u(t,x,y,z) + diff(u(t,x,y,z),t,1) * delta(t,1);

    # 初始条件: 整个立方体初始温度为0
    u(0,x,y,z)=0;

    # 边界条件: 左前下面温度为100，右后上面温度为0
    u(t,0,y,z)=100;
    u(t,400,y,z)=0;
    u(t,x,0,z)=100;
    u(t,x,400,z)=0;
    u(t,x,y,0)=100;
    u(t,x,y,400)=0;
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(t,x,y,z)";
    timeVar:"t";
}