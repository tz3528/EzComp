"""
比较测试结果脚本
1. 编译 reference.cpp (可选，支持 O0/O1/O2/O3 四种优化级别)
2. 运行 ezcomp 编译 .comp 文件
3. 比较运行生成的 result.h5 与预期结果
"""

import argparse
import sys
import os
import subprocess
import glob
import re
import h5py
import numpy as np
import matplotlib.pyplot as plt

# 由 CMake 配置注入
EZCOMP_EXECUTABLE = "@EZCOMP_EXECUTABLE@"
COMPARE_TEST_SOURCE_DIR = "@COMPARE_TEST_SOURCE_DIR@"
CXX_COMPILER = "@CXX_COMPILER@"
HDF5_LIBS = "@EZCOMPUTE_HDF5_LIBS@"
HDF5_INCLUDE_DIRS = "@HDF5_INCLUDE_DIRS@"

# 优化级别
OPT_LEVELS = ["O0", "O1", "O2", "O3"]


def find_comp_file(test_dir):
    """
    在测试目录下查找 .comp 文件

    Args:
        test_dir: 测试目录路径

    Returns:
        .comp 文件的完整路径，如果没找到返回 None
    """
    comp_files = glob.glob(os.path.join(test_dir, '*.comp'))
    if not comp_files:
        return None
    if len(comp_files) > 1:
        print(f"警告: 找到多个 .comp 文件，使用第一个: {comp_files[0]}")
    return comp_files[0]


def find_reference_cpp(test_dir):
    """
    在测试目录下查找 reference.cpp 文件

    Args:
        test_dir: 测试目录路径

    Returns:
        reference.cpp 文件的完整路径，如果没找到返回 None
    """
    ref_file = os.path.join(test_dir, 'reference.cpp')
    if os.path.exists(ref_file):
        return ref_file
    return None


def compile_reference(compiler, ref_cpp, output_dir, opt_level, hdf5_libs, hdf5_include_dirs):
    """
    编译 reference.cpp

    Args:
        compiler: C++ 编译器路径
        ref_cpp: reference.cpp 源文件路径
        output_dir: 输出目录
        opt_level: 优化级别 (O0, O1, O2, O3)
        hdf5_libs: HDF5 库路径列表
        hdf5_include_dirs: HDF5 头文件目录列表

    Returns:
        (success, executable_path): 是否成功，可执行文件路径
    """
    executable_name = f"reference_{opt_level}"
    if sys.platform == "win32":
        executable_name += ".exe"
    executable_path = os.path.join(output_dir, executable_name)

    # 构建编译命令
    cmd = [compiler]
    cmd.append(f"-{opt_level}")
    cmd.extend(["-o", executable_path])
    cmd.append(ref_cpp)

    # 添加 HDF5 头文件目录
    for inc_dir in hdf5_include_dirs.split(';'):
        if inc_dir:
            cmd.extend(["-I", inc_dir])

    # 添加 HDF5 库
    for lib in hdf5_libs.split(';'):
        if lib:
            cmd.append(lib)

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True
        )

        if result.returncode != 0:
            print(f"[{opt_level}] 编译失败:")
            print(result.stderr)
            return False, None

        return True, executable_path

    except FileNotFoundError:
        print(f"错误: 找不到编译器: {compiler}")
        return False, None
    except Exception as e:
        print(f"编译时出错: {str(e)}")
        return False, None


def parse_timer_output(stderr_text):
    """
    解析 reference 程序输出的计时信息

    Args:
        stderr_text: stderr 输出文本

    Returns:
        dict: 计时信息字典，如 {"计算用时": "0h 0m 0s 15ms", ...}
    """
    times = {}
    # 匹配格式: [TIMER] [tag] label: Xh Xm Xs Xms
    pattern = r'\[TIMER\](?:\s+\[([^\]]+)\])?\s+([^:]+):\s+(\d+)h\s+(\d+)m\s+(\d+)s\s+(\d+)ms'
    
    for match in re.finditer(pattern, stderr_text):
        tag, label, hours, minutes, seconds, ms = match.groups()
        time_str = f"{hours}h {minutes}m {seconds}s {ms}ms"
        times[label.strip()] = time_str
    
    return times


def parse_time_to_seconds(time_str):
    """
    将时间字符串转换为秒数

    Args:
        time_str: 时间字符串，如 "0h 0m 1s 652ms"

    Returns:
        float: 秒数
    """
    if not time_str or time_str == "N/A":
        return None
    
    pattern = r'(\d+)h\s+(\d+)m\s+(\d+)s\s+(\d+)ms'
    match = re.match(pattern, time_str)
    if match:
        hours, minutes, seconds, ms = map(int, match.groups())
        return hours * 3600 + minutes * 60 + seconds + ms / 1000.0
    return None


def run_reference(executable, output_file, tag):
    """
    运行参考程序并解析时间

    Args:
        executable: 可执行文件路径
        output_file: 输出 HDF5 文件路径
        tag: 运行标识标签

    Returns:
        (success, times): 是否成功，计时信息字典
    """
    cmd = [executable, output_file, tag]

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True
        )

        if result.returncode != 0:
            print(f"运行失败: {executable}")
            print(result.stderr)
            return False, {}

        # 解析计时信息
        times = parse_timer_output(result.stderr)
        return True, times

    except FileNotFoundError:
        print(f"错误: 找不到可执行文件: {executable}")
        return False, {}
    except Exception as e:
        print(f"运行时出错: {str(e)}")
        return False, {}


def parse_ezcomp_time(stderr_text):
    """
    解析 ezcomp 程序输出的计时信息

    Args:
        stderr_text: stderr 输出文本

    Returns:
        float: 运行时间（秒），如果解析失败返回 None
    """
    # 匹配格式: [TIMER] Xh Xm Xs Xms (无标签格式)
    pattern = r'\[TIMER\]\s+(\d+)h\s+(\d+)m\s+(\d+)s\s+(\d+)ms'
    match = re.search(pattern, stderr_text)
    if match:
        hours, minutes, seconds, ms = map(int, match.groups())
        return hours * 3600 + minutes * 60 + seconds + ms / 1000.0
    return None


def run_ezcomp(ezcomp_path, comp_file, working_dir, test_name):
    """
    运行 ezcomp 编译 .comp 文件，并执行生成的程序

    Args:
        ezcomp_path: ezcomp 可执行文件路径
        comp_file: .comp 源文件路径
        working_dir: 工作目录
        test_name: 测试名称（用于确定生成的可执行文件名）

    Returns:
        (success, return_code, run_time): 是否成功，返回码，运行时间（秒）
    """
    # Step 1: 编译
    cmd = [ezcomp_path, comp_file, '-emit=compile']
    print(f"编译命令: {' '.join(cmd)}")
    print(f"工作目录: {working_dir}")
    print("-" * 50)

    try:
        result = subprocess.run(
            cmd,
            cwd=working_dir,
            capture_output=True,
            text=True
        )

        if result.stdout:
            print(result.stdout)
        if result.stderr:
            print(result.stderr, file=sys.stderr)

        if result.returncode != 0:
            print(f"ezcomp 返回错误码: {result.returncode}")
            return False, result.returncode, None

        print("编译成功")
        print("=" * 50)

    except FileNotFoundError:
        print(f"错误: 找不到 ezcomp 可执行文件: {ezcomp_path}")
        return False, -1, None
    except Exception as e:
        print(f"运行 ezcomp 时出错: {str(e)}")
        return False, -1, None

    # Step 2: 运行生成的可执行文件
    executable = os.path.join(working_dir, test_name)
    if sys.platform == "win32":
        executable += ".exe"

    if not os.path.exists(executable):
        print(f"错误: 找不到生成的可执行文件: {executable}")
        return False, -1, None

    print(f"运行程序: {executable}")
    print("-" * 50)

    try:
        result = subprocess.run(
            [executable],
            cwd=working_dir,
            capture_output=True,
            text=True
        )

        if result.stdout:
            print(result.stdout)
        if result.stderr:
            print(result.stderr, file=sys.stderr)

        if result.returncode != 0:
            print(f"程序返回错误码: {result.returncode}")
            return False, result.returncode, None

        # 解析运行时间
        run_time = parse_ezcomp_time(result.stderr)
        
        print("程序运行成功")
        return True, 0, run_time

    except FileNotFoundError:
        print(f"错误: 找不到可执行文件: {executable}")
        return False, -1, None
    except Exception as e:
        print(f"运行程序时出错: {str(e)}")
        return False, -1, None


def compare_datasets(actual_file, expected_file, rtol=1e-5, atol=1e-8):
    """
    比较两个 HDF5 文件的内容

    Args:
        actual_file: 实际输出文件路径
        expected_file: 预期输出文件路径
        rtol: 相对容差
        atol: 绝对容差

    Returns:
        (success, messages): 是否成功，以及比较信息列表
    """
    messages = []

    if not os.path.exists(actual_file):
        return False, [f"实际输出文件不存在: {actual_file}"]

    if not os.path.exists(expected_file):
        return False, [f"预期输出文件不存在: {expected_file}"]

    try:
        with h5py.File(actual_file, 'r') as f_actual, \
             h5py.File(expected_file, 'r') as f_expected:

            # 检查数据集
            actual_keys = set(f_actual.keys())
            expected_keys = set(f_expected.keys())

            if actual_keys != expected_keys:
                missing_in_actual = expected_keys - actual_keys
                missing_in_expected = actual_keys - expected_keys
                if missing_in_actual:
                    messages.append(f"实际输出缺少数据集: {missing_in_actual}")
                if missing_in_expected:
                    messages.append(f"预期输出缺少数据集: {missing_in_expected}")
                return False, messages

            # 比较 result 数据集
            if 'result' in actual_keys:
                actual_data = f_actual['result'][:]
                expected_data = f_expected['result'][:]

                if actual_data.shape != expected_data.shape:
                    messages.append(f"result 形状不匹配: {actual_data.shape} vs {expected_data.shape}")
                    return False, messages

                if not np.allclose(actual_data, expected_data, rtol=rtol, atol=atol):
                    diff = np.abs(actual_data - expected_data)
                    max_diff = np.max(diff)
                    max_rel_diff = np.max(diff / (np.abs(expected_data) + 1e-10))
                    messages.append(f"result 数据不匹配:")
                    messages.append(f"  最大绝对误差: {max_diff:.6e}")
                    messages.append(f"  最大相对误差: {max_rel_diff:.6e}")
                    return False, messages

                messages.append(f"result 数据集比较通过 (shape={actual_data.shape})")

            # 比较坐标数据集
            for key in actual_keys:
                if key.startswith('coord_'):
                    actual_coords = f_actual[key][:]
                    expected_coords = f_expected[key][:]

                    if not np.allclose(actual_coords, expected_coords, rtol=rtol, atol=atol):
                        messages.append(f"{key} 坐标不匹配")
                        return False, messages
                    messages.append(f"{key} 坐标比较通过")

            return True, messages

    except Exception as e:
        return False, [f"比较过程出错: {str(e)}"]


def print_comparison_table(results):
    """
    打印比较结果表格

    Args:
        results: 结果列表，每个元素为 (opt_level, compute_time, output_time, match)
    """
    # 计算列宽
    opt_width = max(len("优化级别"), max(len(r[0]) for r in results))
    compute_width = max(len("计算用时"), max(len(r[1]) if r[1] else 3 for r in results))
    output_width = max(len("输出用时"), max(len(r[2]) if r[2] else 3 for r in results))
    match_width = len("是否匹配")

    # 表头
    header = f"┌─{'─' * opt_width}─┬─{'─' * compute_width}─┬─{'─' * output_width}─┬─{'─' * match_width}─┐"
    separator = f"├─{'─' * opt_width}─┼─{'─' * compute_width}─┼─{'─' * output_width}─┼─{'─' * match_width}─┤"
    footer = f"└─{'─' * opt_width}─┴─{'─' * compute_width}─┴─{'─' * output_width}─┴─{'─' * match_width}─┘"

    print(header)
    print(f"│ {'优化级别'.ljust(opt_width)} │ {'计算用时'.ljust(compute_width)} │ {'输出用时'.ljust(output_width)} │ {'是否匹配'.ljust(match_width)} │")
    print(separator)

    for opt, compute, output, match in results:
        compute_str = compute if compute else "N/A"
        output_str = output if output else "N/A"
        match_str = "✓" if match else "✗"
        print(f"│ {opt.ljust(opt_width)} │ {compute_str.ljust(compute_width)} │ {output_str.ljust(output_width)} │ {match_str.ljust(match_width)} │")

    print(footer)


def verify_results(all_data, rtol=1e-6):
    """
    验证 ezcomp 结果与参考结果的相对误差

    Args:
        all_data: 所有数据的字典
        rtol: 相对容差

    Returns:
        (success, error_messages): 是否全部通过，错误信息列表
    """
    errors = []
    
    if 'ezcomp' not in all_data:
        errors.append("ezcomp 结果不存在")
        return False, errors
    
    ezcomp_result = all_data['ezcomp']['result']
    if ezcomp_result is None:
        errors.append("ezcomp 结果中没有 'result' 数据集")
        return False, errors
    
    # 使用 O3 作为参考基准
    ref_key = 'O3'
    if ref_key not in all_data:
        errors.append(f"参考结果 {ref_key} 不存在")
        return False, errors
    
    ref_result = all_data[ref_key]['result']
    if ref_result is None:
        errors.append(f"参考结果 {ref_key} 中没有 'result' 数据集")
        return False, errors
    
    # 检查形状
    if ezcomp_result.shape != ref_result.shape:
        errors.append(f"结果形状不匹配: ezcomp {ezcomp_result.shape} vs 参考 {ref_result.shape}")
        return False, errors
    
    # 检查 NaN 和 Inf
    ezcomp_nan_count = np.sum(np.isnan(ezcomp_result))
    ezcomp_inf_count = np.sum(np.isinf(ezcomp_result))
    ref_nan_count = np.sum(np.isnan(ref_result))
    ref_inf_count = np.sum(np.isinf(ref_result))
    
    if ezcomp_nan_count > 0:
        errors.append(f"ezcomp 结果包含 {ezcomp_nan_count} 个 NaN 值")
    if ezcomp_inf_count > 0:
        errors.append(f"ezcomp 结果包含 {ezcomp_inf_count} 个 Inf 值")
    
    if errors:
        return False, errors
    
    # 计算相对误差（避免除以零）
    abs_diff = np.abs(ezcomp_result - ref_result)
    
    with np.errstate(divide='ignore', invalid='ignore'):
        rel_diff = np.abs(ezcomp_result - ref_result) / np.abs(ref_result)
        rel_diff = np.where(np.abs(ref_result) < 1e-10, abs_diff, rel_diff)
    
    max_abs_diff = np.max(abs_diff)
    max_rel_diff = np.nanmax(rel_diff)
    
    # 找到最大误差的位置
    max_rel_idx = np.unravel_index(np.nanargmax(rel_diff), rel_diff.shape)
    
    print(f"\n结果验证 (相对容差: {rtol}):")
    print(f"  最大绝对误差: {max_abs_diff:.6e}")
    print(f"  最大相对误差: {max_rel_diff:.6e}")
    print(f"  最大相对误差位置: {max_rel_idx}")
    print(f"  该位置 ezcomp 值: {ezcomp_result[max_rel_idx]:.6e}")
    print(f"  该位置参考值: {ref_result[max_rel_idx]:.6e}")
    
    if max_rel_diff > rtol:
        errors.append(f"最大相对误差 {max_rel_diff:.6e} 超过容差 {rtol}")
        return False, errors
    
    print(f"  ✓ 结果验证通过!")
    return True, errors


def plot_performance(all_data, ezcomp_time, output_path="performance_comparison.png"):
    """
    绘制性能比较图

    Args:
        all_data: 所有数据的字典
        ezcomp_time: ezcomp 运行时间（秒）
        output_path: 输出图片路径
    """
    labels = []
    times = []
    colors = []
    
    # 收集参考程序的时间
    for opt in OPT_LEVELS:
        if opt in all_data:
            time_str = all_data[opt].get('compute_time', 'N/A')
            time_sec = parse_time_to_seconds(time_str)
            if time_sec is not None:
                labels.append(f"Ref-{opt}")
                times.append(time_sec)
                colors.append('#3498db')  # 蓝色
    
    # 添加 ezcomp 时间
    if ezcomp_time is not None:
        labels.append("EzComp")
        times.append(ezcomp_time)
        colors.append('#e74c3c')  # 红色
    
    if not labels:
        print("没有足够的数据来绘制性能比较图")
        return
    
    # 创建图表
    fig, ax = plt.subplots(figsize=(10, 6))
    
    x = np.arange(len(labels))
    bars = ax.bar(x, times, color=colors, edgecolor='black', linewidth=1.2)
    
    # 设置标签 (使用英文避免字体问题)
    ax.set_xlabel('Version', fontsize=12)
    ax.set_ylabel('Compute Time (seconds)', fontsize=12)
    ax.set_title('Performance Comparison: EzComp vs Reference', fontsize=14, fontweight='bold')
    ax.set_xticks(x)
    ax.set_xticklabels(labels, fontsize=11)
    
    # 在柱状图上显示数值
    for bar, time_val in zip(bars, times):
        height = bar.get_height()
        ax.annotate(f'{time_val:.3f}s',
                    xy=(bar.get_x() + bar.get_width() / 2, height),
                    xytext=(0, 3),
                    textcoords="offset points",
                    ha='center', va='bottom', fontsize=10)
    
    # 设置 y 轴范围，留出空间显示数值
    ax.set_ylim(0, max(times) * 1.15)
    
    # 添加网格线
    ax.yaxis.grid(True, linestyle='--', alpha=0.7)
    ax.set_axisbelow(True)
    
    # 添加图例
    from matplotlib.patches import Patch
    legend_elements = [
        Patch(facecolor='#3498db', edgecolor='black', label='Reference (C++)'),
        Patch(facecolor='#e74c3c', edgecolor='black', label='EzComp')
    ]
    ax.legend(handles=legend_elements, loc='upper right')
    
    plt.tight_layout()
    plt.savefig(output_path, dpi=150, bbox_inches='tight')
    print(f"\nPerformance comparison chart saved to: {output_path}")
    plt.close()


def main():
    parser = argparse.ArgumentParser(description='比较测试结果')
    parser.add_argument('test_dir', nargs='?', default=os.environ.get('COMPARE_TEST_DIR', ''),
                        help='测试目录名 (也可通过环境变量 COMPARE_TEST_DIR 设置)')
    parser.add_argument('--rtol', type=float, default=1e-6, help='相对容差 (默认: 1e-6)')
    parser.add_argument('--atol', type=float, default=1e-8, help='绝对容差')
    parser.add_argument('--no-plot', action='store_true', help='不生成性能比较图')

    args = parser.parse_args()

    if not args.test_dir:
        parser.error("需要指定测试目录名，用法: compare.py <test_dir> 或设置环境变量 COMPARE_TEST_DIR")

    # 确定测试目录路径 (使用源码目录)
    test_dir_path = os.path.join(COMPARE_TEST_SOURCE_DIR, args.test_dir)

    if not os.path.isdir(test_dir_path):
        print(f"错误: 测试目录不存在: {test_dir_path}")
        return 1

    # 查找 .comp 文件
    comp_file = find_comp_file(test_dir_path)
    if not comp_file:
        print(f"错误: 在目录 {test_dir_path} 中未找到 .comp 文件")
        return 1

    # 查找 reference.cpp
    ref_cpp = find_reference_cpp(test_dir_path)
    if not ref_cpp:
        print(f"错误: 在目录 {test_dir_path} 中未找到 reference.cpp")
        return 1

    print(f"测试目录: {args.test_dir}")
    print(f"Comp 文件: {comp_file}")
    print(f"Reference: {ref_cpp}")
    print(f"ezcomp: {EZCOMP_EXECUTABLE}")
    print(f"编译器: {CXX_COMPILER}")
    print("=" * 50)

    # ========== 编译 reference.cpp ==========
    print("========== 编译 reference.cpp ==========")
    compiled_refs = {}
    for opt in OPT_LEVELS:
        success, exe_path = compile_reference(
            CXX_COMPILER, ref_cpp, os.getcwd(), opt, HDF5_LIBS, HDF5_INCLUDE_DIRS
        )
        if success:
            print(f"[{opt}] 编译成功: {exe_path}")
            compiled_refs[opt] = exe_path
        else:
            print(f"[{opt}] 编译失败")

    print("=" * 50)

    # ========== 运行参考程序 ==========
    print("========== 运行参考程序 ==========")
    ref_results = {}
    for opt, exe_path in compiled_refs.items():
        output_file = f"result_{opt}.h5"
        success, times = run_reference(exe_path, output_file, opt)
        if success:
            compute_time = times.get("计算用时", "N/A")
            output_time = times.get("输出 HDF5 文件", "N/A")
            print(f"[{opt}] 计算用时: {compute_time}, 输出用时: {output_time}")
            ref_results[opt] = {
                'compute_time': compute_time,
                'output_time': output_time,
                'output_file': output_file
            }

    print("=" * 50)

    # ========== 运行 ezcomp 编译 ==========
    print("========== 运行 ezcomp ==========")
    success, return_code, ezcomp_time = run_ezcomp(EZCOMP_EXECUTABLE, comp_file, os.getcwd(), args.test_dir)
    if not success:
        print("=" * 50)
        print("ezcomp 编译或运行失败")
        return 1
    print("=" * 50)

    # ========== 读取所有数据 ==========
    print("========== 读取数据 ==========")
    
    # 存储所有数据的字典
    all_data = {}
    
    # 读取 ezcomp 生成的 result.h5
    ezcomp_file = "result.h5"
    if os.path.exists(ezcomp_file):
        with h5py.File(ezcomp_file, 'r') as f:
            all_data['ezcomp'] = {
                'result': f['result'][:] if 'result' in f else None,
                'datasets': list(f.keys())
            }
            print(f"ezcomp result.h5: 数据集 {all_data['ezcomp']['datasets']}")
    
    # 读取各优化级别的 result_O{X}.h5
    for opt in OPT_LEVELS:
        ref_file = f"result_{opt}.h5"
        if os.path.exists(ref_file):
            with h5py.File(ref_file, 'r') as f:
                all_data[opt] = {
                    'result': f['result'][:] if 'result' in f else None,
                    'datasets': list(f.keys()),
                    'compute_time': ref_results.get(opt, {}).get('compute_time', 'N/A'),
                    'output_time': ref_results.get(opt, {}).get('output_time', 'N/A')
                }
                print(f"{opt} result_{opt}.h5: 数据集 {all_data[opt]['datasets']}")
    
    print("=" * 50)
    
    # ========== 验证结果 ==========
    print("========== 验证结果 ==========")
    passed, errors = verify_results(all_data, rtol=args.rtol)
    
    if not passed:
        print("\n❌ 结果验证失败!")
        for err in errors:
            print(f"  错误: {err}")
        return 1
    
    print("=" * 50)
    
    # ========== 绘制性能比较图 ==========
    if not args.no_plot:
        print("========== 绘制性能比较图 ==========")
        plot_performance(all_data, ezcomp_time, output_path=os.path.join(os.getcwd(), "performance_comparison.png"))
        print("=" * 50)
    
    print("\n✅ 所有测试通过!")
    return 0


if __name__ == '__main__':
    sys.exit(main())