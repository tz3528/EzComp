"""
比较测试结果脚本
1. 编译 reference.cpp (支持 O2/O3 两种优化级别)
2. 编译 ezcomp 的 .comp 文件（支持多种 pass-pipeline 配置）
3. 多次运行（默认10次），随机顺序执行，取平均值
4. 比较运行生成的 result.h5 与预期结果
5. 绘制性能比较图（显示相对于 O2 的加速比）
"""

import argparse
import sys
import os
import subprocess
import glob
import re
import random
import time
import shutil
import h5py
import numpy as np
import matplotlib.pyplot as plt

# 由 CMake 配置注入
EZCOMP_EXECUTABLE = "@EZCOMP_EXECUTABLE@"
COMPARE_TEST_SOURCE_DIR = "@COMPARE_TEST_SOURCE_DIR@"
CXX_COMPILER = "@CXX_COMPILER@"
HDF5_LIBS = "@EZCOMPUTE_HDF5_LIBS@"
HDF5_INCLUDE_DIRS = "@HDF5_INCLUDE_DIRS@"

# 优化级别
OPT_LEVELS = ["O2", "O3"]

# EzComp 编译配置
# key: 配置标识, label: 显示标签, emit: -emit 参数, pipeline: --pass-pipeline 参数, output_name: 输出可执行文件名后缀
EZCOMP_CONFIGS = [
    {
        'key': 'ezcomp_no_opt',
        'label': 'EzComp-NoOpt',
        'emit': 'compile',
        'pipeline': 'builtin.module(lowering{base-llvm})',
        'output_name': 'no_opt'
    },
    {
        'key': 'ezcomp_vectorize',
        'label': 'EzComp-Vec',
        'emit': 'compile',
        'pipeline': 'builtin.module(lowering{base-llvm hoist-boundary affine-vectorize})',
        'output_name': 'vectorize'
    },
]

# EzComp 统一颜色
EZCOMP_COLOR = '#e74c3c'  # 红色

# 每个测试运行的次数
NUM_RUNS = 10


def find_comp_file(test_dir):
    """
    在测试目录下查找 .comp 文件

    Args:
        test_dir: 测试目录路径

    Returns:
        .comp 文件的完整路径，如果没找到返回 None
    """
    comp_files = glob.glob(os.path.join(test_dir, '*.comp'))
    if not comp_files:
        return None
    if len(comp_files) > 1:
        print(f"警告: 找到多个 .comp 文件，使用第一个: {comp_files[0]}")
    return comp_files[0]


def find_reference_cpp(test_dir):
    """
    在测试目录下查找 reference.cpp 文件

    Args:
        test_dir: 测试目录路径

    Returns:
        reference.cpp 文件的完整路径，如果没找到返回 None
    """
    ref_file = os.path.join(test_dir, 'reference.cpp')
    if os.path.exists(ref_file):
        return ref_file
    return None


def compile_reference(compiler, ref_cpp, output_dir, opt_level, hdf5_libs, hdf5_include_dirs):
    """
    编译 reference.cpp

    Args:
        compiler: C++ 编译器路径
        ref_cpp: reference.cpp 源文件路径
        output_dir: 输出目录
        opt_level: 优化级别 (O1, O2, O3)
        hdf5_libs: HDF5 库路径列表
        hdf5_include_dirs: HDF5 头文件目录列表

    Returns:
        (success, executable_path): 是否成功，可执行文件路径
    """
    executable_name = f"reference_{opt_level}"
    if sys.platform == "win32":
        executable_name += ".exe"
    executable_path = os.path.join(output_dir, executable_name)

    # 构建编译命令
    cmd = [compiler]
    cmd.append(f"-{opt_level}")
    cmd.extend(["-o", executable_path])
    cmd.append(ref_cpp)

    # 添加 HDF5 头文件目录
    for inc_dir in hdf5_include_dirs.split(';'):
        if inc_dir:
            cmd.extend(["-I", inc_dir])

    # 添加 HDF5 库
    for lib in hdf5_libs.split(';'):
        if lib:
            cmd.append(lib)

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True
        )

        if result.returncode != 0:
            print(f"[{opt_level}] 编译失败:")
            print(result.stderr)
            return False, None

        return True, executable_path

    except FileNotFoundError:
        print(f"错误: 找不到编译器: {compiler}")
        return False, None
    except Exception as e:
        print(f"编译时出错: {str(e)}")
        return False, None


def parse_timer_output(stderr_text):
    """
    解析程序输出的计时信息

    Args:
        stderr_text: stderr 输出文本

    Returns:
        dict: 计时信息字典，如 {"计算用时": "0h 0m 0s 15ms", ...}
              无标签格式时使用 "default" 作为 key
    """
    times = {}
    # 匹配有标签格式: [TIMER] [tag] label: Xh Xm Xs Xms
    labeled_pattern = r'\[TIMER\](?:\s+\[([^\]]+)\])?\s+([^:]+):\s+(\d+)h\s+(\d+)m\s+(\d+)s\s+(\d+)ms'

    for match in re.finditer(labeled_pattern, stderr_text):
        tag, label, hours, minutes, seconds, ms = match.groups()
        time_str = f"{hours}h {minutes}m {seconds}s {ms}ms"
        times[label.strip()] = time_str

    # 匹配无标签格式: [TIMER] Xh Xm Xs Xms
    if not times:
        simple_pattern = r'\[TIMER\]\s+(\d+)h\s+(\d+)m\s+(\d+)s\s+(\d+)ms'
        match = re.search(simple_pattern, stderr_text)
        if match:
            hours, minutes, seconds, ms = match.groups()
            times['default'] = f"{hours}h {minutes}m {seconds}s {ms}ms"

    return times


def parse_time_to_seconds(time_str):
    """
    将时间字符串转换为秒数

    Args:
        time_str: 时间字符串，如 "0h 0m 1s 652ms"

    Returns:
        float: 秒数
    """
    if not time_str or time_str == "N/A":
        return None
    
    pattern = r'(\d+)h\s+(\d+)m\s+(\d+)s\s+(\d+)ms'
    match = re.match(pattern, time_str)
    if match:
        hours, minutes, seconds, ms = map(int, match.groups())
        return hours * 3600 + minutes * 60 + seconds + ms / 1000.0
    return None


def run_reference(executable, output_file, tag):
    """
    运行参考程序并解析时间

    Args:
        executable: 可执行文件路径
        output_file: 输出 HDF5 文件路径
        tag: 运行标识标签

    Returns:
        (success, run_time): 是否成功，运行时间（秒）
    """
    cmd = [executable, output_file, tag]

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True
        )

        if result.returncode != 0:
            print(f"运行失败: {executable}")
            print(result.stderr)
            return False, None

        # 解析计时信息
        times = parse_timer_output(result.stderr)
        time_str = times.get('计算用时') or times.get('default')
        run_time = parse_time_to_seconds(time_str)
        return True, run_time

    except FileNotFoundError:
        print(f"错误: 找不到可执行文件: {executable}")
        return False, None
    except Exception as e:
        print(f"运行时出错: {str(e)}")
        return False, None


def compile_ezcomp(ezcomp_path, comp_file, working_dir, test_name, output_name, emit='compile', pipeline=None):
    """
    编译 ezcomp .comp 文件

    Args:
        ezcomp_path: ezcomp 可执行文件路径
        comp_file: .comp 源文件路径
        working_dir: 工作目录
        test_name: 测试名称（ezcomp 生成的默认可执行文件名）
        output_name: 编译后重命名的目标文件名
        emit: -emit 参数值 (compile, mlir, llvm, etc.)
        pipeline: --pass-pipeline 参数值 (可选)

    Returns:
        (success, executable_path): 是否成功，重命名后的可执行文件路径
    """
    import shutil
    
    cmd = [ezcomp_path, comp_file, f'-emit={emit}']
    if pipeline:
        cmd.append(f'--pass-pipeline={pipeline}')
    
    print(f"编译命令: {' '.join(cmd)}")
    print(f"工作目录: {working_dir}")
    print("-" * 50)

    try:
        result = subprocess.run(
            cmd,
            cwd=working_dir,
            capture_output=True,
            text=True
        )

        if result.stdout:
            print(result.stdout)
        if result.stderr:
            print(result.stderr, file=sys.stderr)

        if result.returncode != 0:
            print(f"ezcomp 返回错误码: {result.returncode}")
            return False, None

        print("编译成功")

    except FileNotFoundError:
        print(f"错误: 找不到 ezcomp 可执行文件: {ezcomp_path}")
        return False, None
    except Exception as e:
        print(f"运行 ezcomp 时出错: {str(e)}")
        return False, None

    # 默认生成的可执行文件路径
    default_executable = os.path.join(working_dir, test_name)
    if sys.platform == "win32":
        default_executable += ".exe"

    if not os.path.exists(default_executable):
        print(f"错误: 找不到生成的可执行文件: {default_executable}")
        return False, None

    # 重命名为目标文件名
    target_executable = os.path.join(working_dir, output_name)
    if sys.platform == "win32":
        target_executable += ".exe"
    
    # 如果目标文件已存在，先删除
    if os.path.exists(target_executable):
        os.remove(target_executable)
    
    shutil.move(default_executable, target_executable)
    print(f"重命名: {default_executable} -> {target_executable}")
    print("=" * 50)

    return True, target_executable


def run_ezcomp_executable(executable, working_dir):
    """
    运行 ezcomp 编译生成的可执行文件

    Args:
        executable: 可执行文件路径
        working_dir: 工作目录

    Returns:
        (success, run_time): 是否成功，运行时间（秒）
    """
    try:
        result = subprocess.run(
            [executable],
            cwd=working_dir,
            capture_output=True,
            text=True
        )

        if result.returncode != 0:
            print(f"程序返回错误码: {result.returncode}")
            return False, None

        # 解析运行时间
        times = parse_timer_output(result.stderr)
        time_str = times.get('计算用时') or times.get('default')
        run_time = parse_time_to_seconds(time_str)

        return True, run_time

    except FileNotFoundError:
        print(f"错误: 找不到可执行文件: {executable}")
        return False, None
    except Exception as e:
        print(f"运行程序时出错: {str(e)}")
        return False, None


def verify_results(all_data, rtol=1e-6):
    """
    验证 ezcomp 结果与参考结果的相对误差

    Args:
        all_data: 所有数据的字典
        rtol: 相对容差

    Returns:
        (success, error_messages): 是否全部通过，错误信息列表
    """
    errors = []
    
    if 'ezcomp' not in all_data:
        errors.append("ezcomp 结果不存在")
        return False, errors
    
    ezcomp_result = all_data['ezcomp']['result']
    if ezcomp_result is None:
        errors.append("ezcomp 结果中没有 'result' 数据集")
        return False, errors
    
    # 使用 O3 作为参考基准
    ref_key = 'O3'
    if ref_key not in all_data:
        errors.append(f"参考结果 {ref_key} 不存在")
        return False, errors
    
    ref_result = all_data[ref_key]['result']
    if ref_result is None:
        errors.append(f"参考结果 {ref_key} 中没有 'result' 数据集")
        return False, errors
    
    # 检查形状
    if ezcomp_result.shape != ref_result.shape:
        errors.append(f"结果形状不匹配: ezcomp {ezcomp_result.shape} vs 参考 {ref_result.shape}")
        return False, errors
    
    # 检查 NaN 和 Inf
    ezcomp_nan_count = np.sum(np.isnan(ezcomp_result))
    ezcomp_inf_count = np.sum(np.isinf(ezcomp_result))
    
    if ezcomp_nan_count > 0:
        errors.append(f"ezcomp 结果包含 {ezcomp_nan_count} 个 NaN 值")
    if ezcomp_inf_count > 0:
        errors.append(f"ezcomp 结果包含 {ezcomp_inf_count} 个 Inf 值")
    
    if errors:
        return False, errors
    
    # 计算相对误差（避免除以零）
    abs_diff = np.abs(ezcomp_result - ref_result)
    
    with np.errstate(divide='ignore', invalid='ignore'):
        rel_diff = abs_diff / np.abs(ref_result)
        rel_diff = np.where(np.abs(ref_result) < 1e-10, abs_diff, rel_diff)
    
    max_abs_diff = np.max(abs_diff)
    max_rel_diff = np.nanmax(rel_diff)
    
    # 找到最大误差的位置
    max_rel_idx = np.unravel_index(np.nanargmax(rel_diff), rel_diff.shape)
    
    print(f"\n结果验证:")
    print(f"  最大绝对误差: {max_abs_diff:.6e}")
    print(f"  最大相对误差: {max_rel_diff:.6e}")
    print(f"  最大相对误差位置: {max_rel_idx}")
    print(f"  该位置 ezcomp 值: {ezcomp_result[max_rel_idx]:.6e}")
    print(f"  该位置参考值: {ref_result[max_rel_idx]:.6e}")
    
    if max_rel_diff > rtol:
        errors.append(f"最大相对误差 {max_rel_diff:.6e} 超过容差 {rtol}")
        return False, errors
    
    print(f"  ✓ 结果验证通过!")
    return True, errors


def plot_performance(perf_data, output_path="performance_comparison.png"):
    """
    绘制性能比较图

    Args:
        perf_data: 性能数据字典，包含 labels, times, colors
        output_path: 输出图片路径
    """
    labels = perf_data['labels']
    times = perf_data['times']
    colors = perf_data['colors']
    
    if not labels:
        print("没有足够的数据来绘制性能比较图")
        return
    
    # 获取 O2 的基准时间用于计算加速比
    baseline_time = None
    for i, label in enumerate(labels):
        if label == "Ref-O2":
            baseline_time = times[i]
            break
    
    # 创建图表
    fig, ax = plt.subplots(figsize=(12, 6))
    
    x = np.arange(len(labels))
    bars = ax.bar(x, times, color=colors, edgecolor='black', linewidth=1.2)
    
    # 设置标签 (使用英文避免字体问题)
    ax.set_xlabel('Version', fontsize=12)
    ax.set_ylabel('Compute Time (seconds)', fontsize=12)
    ax.set_title('Performance Comparison: EzComp vs Reference (10 runs average)', fontsize=14, fontweight='bold')
    ax.set_xticks(x)
    ax.set_xticklabels(labels, fontsize=11)
    
    # 在柱状图上显示数值（时间和加速比）
    for bar, time_val, label in zip(bars, times, labels):
        height = bar.get_height()
        # 计算加速比
        if baseline_time is not None and label == "Ref-O2":
            annotation = f'{time_val:.3f}s\n(baseline)'
        elif baseline_time is not None and baseline_time > 0:
            speedup = baseline_time / time_val
            annotation = f'{time_val:.3f}s\n({speedup:.2f}x)'
        else:
            annotation = f'{time_val:.3f}s'
        
        ax.annotate(annotation,
                    xy=(bar.get_x() + bar.get_width() / 2, height),
                    xytext=(0, 3),
                    textcoords="offset points",
                    ha='center', va='bottom', fontsize=9)
    
    # 设置 y 轴范围，留出空间显示数值
    ax.set_ylim(0, max(times) * 1.2)
    
    # 添加网格线
    ax.yaxis.grid(True, linestyle='--', alpha=0.7)
    ax.set_axisbelow(True)
    
    # 添加图例（动态生成）
    from matplotlib.patches import Patch
    legend_elements = [
        Patch(facecolor='#3498db', edgecolor='black', label='Reference (C++)'),
        Patch(facecolor=EZCOMP_COLOR, edgecolor='black', label='EzComp'),
    ]
    ax.legend(handles=legend_elements, loc='upper right')
    
    plt.tight_layout()
    plt.savefig(output_path, dpi=150, bbox_inches='tight')
    print(f"\nPerformance comparison chart saved to: {output_path}")
    plt.close()


def main():
    parser = argparse.ArgumentParser(description='比较测试结果')
    parser.add_argument('test_dir', nargs='?', default=os.environ.get('COMPARE_TEST_DIR', ''),
                        help='测试目录名 (也可通过环境变量 COMPARE_TEST_DIR 设置)')
    parser.add_argument('--rtol', type=float, default=1e-6, help='相对容差 (默认: 1e-6)')
    parser.add_argument('--no-plot', action='store_true', help='不生成性能比较图')
    parser.add_argument('--runs', type=int, default=NUM_RUNS, help=f'运行次数 (默认: {NUM_RUNS})')

    args = parser.parse_args()

    if not args.test_dir:
        parser.error("需要指定测试目录名，用法: compare.py <test_dir> 或设置环境变量 COMPARE_TEST_DIR")

    # 确定测试目录路径 (使用源码目录)
    test_dir_path = os.path.join(COMPARE_TEST_SOURCE_DIR, args.test_dir)

    if not os.path.isdir(test_dir_path):
        print(f"错误: 测试目录不存在: {test_dir_path}")
        return 1

    # 查找 .comp 文件
    comp_file = find_comp_file(test_dir_path)
    if not comp_file:
        print(f"错误: 在目录 {test_dir_path} 中未找到 .comp 文件")
        return 1

    # 查找 reference.cpp
    ref_cpp = find_reference_cpp(test_dir_path)
    if not ref_cpp:
        print(f"错误: 在目录 {test_dir_path} 中未找到 reference.cpp")
        return 1

    print(f"测试目录: {args.test_dir}")
    print(f"Comp 文件: {comp_file}")
    print(f"Reference: {ref_cpp}")
    print(f"ezcomp: {EZCOMP_EXECUTABLE}")
    print(f"编译器: {CXX_COMPILER}")
    print(f"运行次数: {args.runs}")
    print("=" * 50)

    # ========== 编译 reference.cpp ==========
    print("========== 编译 reference.cpp ==========")
    compiled_refs = {}
    for opt in OPT_LEVELS:
        success, exe_path = compile_reference(
            CXX_COMPILER, ref_cpp, os.getcwd(), opt, HDF5_LIBS, HDF5_INCLUDE_DIRS
        )
        if success:
            print(f"[{opt}] 编译成功: {exe_path}")
            compiled_refs[opt] = exe_path
        else:
            print(f"[{opt}] 编译失败")

    print("=" * 50)

    # ========== 编译 ezcomp 各配置 ==========
    print("========== 编译 EzComp ==========")
    compiled_ezcomps = {}
    for config in EZCOMP_CONFIGS:
        config_key = config['key']
        config_label = config['label']
        output_name = f"{args.test_dir}_{config['output_name']}"
        print(f"--- {config_label} ---")
        success, exe_path = compile_ezcomp(
            EZCOMP_EXECUTABLE, comp_file, os.getcwd(), 
            args.test_dir,  # 默认生成的可执行文件名
            output_name,    # 重命名后的目标文件名
            emit=config['emit'], 
            pipeline=config.get('pipeline')
        )
        if success:
            print(f"[{config_label}] 编译成功: {exe_path}")
            compiled_ezcomps[config_key] = {
                'exe': exe_path,
                'label': config['label']
            }
        else:
            print(f"[{config_label}] 编译失败")
            return 1
    print("=" * 50)

    # ========== 多次运行性能测试 ==========
    print(f"========== 运行性能测试 ({args.runs} 次) ==========")
    
    # 存储各版本的运行时间列表
    run_times = {opt: [] for opt in OPT_LEVELS}
    for config_key in compiled_ezcomps:
        run_times[config_key] = []
    
    # 按轮次构建任务列表，每轮随机打乱顺序
    for run_idx in range(args.runs):
        round_start = time.time()
        
        # 构建本轮任务
        round_tasks = []
        for opt in OPT_LEVELS:
            if opt in compiled_refs:
                round_tasks.append(('ref', opt))
        for config_key in compiled_ezcomps:
            round_tasks.append(('ezcomp', config_key))
        
        # 随机打乱本轮顺序
        random.shuffle(round_tasks)
        
        # 执行本轮任务
        for task_type, version_key in round_tasks:
            if task_type == 'ezcomp':
                config_info = compiled_ezcomps[version_key]
                success, run_time = run_ezcomp_executable(config_info['exe'], os.getcwd())
                if success:
                    run_times[version_key].append(run_time)
                else:
                    print(f"Round {run_idx + 1}: {config_info['label']} 失败")
                    return 1
            else:
                opt = version_key
                output_file = f"result_{opt}_{run_idx}.h5"
                success, run_time = run_reference(compiled_refs[opt], output_file, f"{opt}_{run_idx}")
                if success:
                    run_times[opt].append(run_time)
                else:
                    print(f"Round {run_idx + 1}: Ref-{opt} 失败")
                    return 1
        
        round_end = time.time()
        round_time = round_end - round_start
        print(f"Round {run_idx + 1}/{args.runs} 完成，本轮用时: {round_time:.3f}s")

    print("=" * 50)

    # ========== 计算统计结果 ==========
    print("========== 统计结果 ==========")
    
    perf_data = {
        'labels': [],
        'times': [],
        'colors': []
    }
    
    for opt in OPT_LEVELS:
        if run_times[opt]:
            times_arr = np.array(run_times[opt])
            avg_time = np.mean(times_arr)
            std_time = np.std(times_arr)
            print(f"Ref-{opt}: 平均 {avg_time:.3f}s ± {std_time:.3f}s (n={len(times_arr)})")
            perf_data['labels'].append(f"Ref-{opt}")
            perf_data['times'].append(avg_time)
            perf_data['colors'].append('#3498db')  # 蓝色
    
    for config in EZCOMP_CONFIGS:
        config_key = config['key']
        config_label = config['label']
        if run_times.get(config_key):
            times_arr = np.array(run_times[config_key])
            avg_time = np.mean(times_arr)
            std_time = np.std(times_arr)
            print(f"{config_label}: 平均 {avg_time:.3f}s ± {std_time:.3f}s (n={len(times_arr)})")
            perf_data['labels'].append(config_label)
            perf_data['times'].append(avg_time)
            perf_data['colors'].append(EZCOMP_COLOR)
    
    print("=" * 50)

    # ========== 读取数据进行验证 ==========
    print("========== 验证结果 ==========")
    
    # 存储所有数据的字典
    all_data = {}
    
    # 读取 ezcomp 生成的 result.h5 (使用最后一个配置的结果)
    ezcomp_file = "result.h5"
    if os.path.exists(ezcomp_file):
        with h5py.File(ezcomp_file, 'r') as f:
            all_data['ezcomp'] = {
                'result': f['result'][:] if 'result' in f else None,
                'datasets': list(f.keys())
            }
            print(f"ezcomp result.h5: 数据集 {all_data['ezcomp']['datasets']}")
    
    # 读取最后一次 O3 运行结果作为参考
    ref_key = 'O3'
    last_ref_file = f"result_{ref_key}_{args.runs - 1}.h5"
    if os.path.exists(last_ref_file):
        with h5py.File(last_ref_file, 'r') as f:
            all_data[ref_key] = {
                'result': f['result'][:] if 'result' in f else None,
                'datasets': list(f.keys())
            }
            print(f"{ref_key} {last_ref_file}: 数据集 {all_data[ref_key]['datasets']}")
    
    passed, errors = verify_results(all_data, rtol=args.rtol)
    
    if not passed:
        print("\n❌ 结果验证失败!")
        for err in errors:
            print(f"  错误: {err}")
        return 1
    
    print("=" * 50)
    
    # ========== 绘制性能比较图 ==========
    if not args.no_plot:
        print("========== 绘制性能比较图 ==========")
        plot_performance(perf_data, output_path=os.path.join(os.getcwd(), "performance_comparison.png"))
        print("=" * 50)
    
    print("\n✅ 所有测试通过!")
    return 0


if __name__ == '__main__':
    sys.exit(main())