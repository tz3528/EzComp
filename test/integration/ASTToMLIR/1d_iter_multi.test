#===-- 1d_iter_multi.test -------------------------------------*-- Comp -*-===#
#
# 1D: 多个迭代方程（通过 diff 函数分解）
# diff(u,t) = ... 和 u(x,t+1) = u(x,t) + diff(u,t)
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir | FileCheck %s

# ===== 顶层结构 =====
# CHECK-LABEL: comp.problem
# CHECK: comp.dim @t
# CHECK: comp.dim @x
# CHECK: comp.field @u(spaceDims = [@x], timeDim = @t)
# CHECK: comp.solve

# ===== 初始化块 =====
# CHECK-LABEL: comp.apply_init
# CHECK: comp.coord @x
# CHECK: comp.coord @t
# CHECK: comp.yield

# ===== 边界条件块 =====
# CHECK-LABEL: comp.dirichlet
# CHECK: comp.coord @t
# CHECK: comp.coord @x
# CHECK: comp.yield

# CHECK: comp.dirichlet
# CHECK: comp.coord @t
# CHECK: comp.coord @x
# CHECK: comp.yield

# ===== 迭代块：检查维度顺序正确（时间维在前：[@t, @x]），多个sample顺序任意 =====
# CHECK-LABEL: comp.for_time
# CHECK: comp.coord @t
# CHECK: comp.update
# CHECK: comp.coord @x
# CHECK-DAG: comp.sample {{.*}} dims = [@t, @x] shift = [0, -1]
# CHECK-DAG: comp.sample {{.*}} dims = [@t, @x] shift = [0, 0]
# CHECK-DAG: comp.sample {{.*}} dims = [@t, @x] shift = [0, 1]
# CHECK-DAG: comp.sample {{.*}} dims = [@t, @x] shift = [1, 0]
# CHECK: comp.delta @x 2 : f64
# CHECK: comp.yield

declarations {
    x[0,50,51];
    t[0,100,101];
}

equations {
    u(x,0) = 0;
    u(0,t) = 100;
    u(50,t) = 0;
    diff(u(x,t),x,2) = (u(x-1,t)+u(x+1,t)-2*u(x,t))/delta(x,2);
    u(x,t+1) = u(x,t) + diff(u(x,t),x,2);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}