#===-- 1d_init_with_pos.test ----------------------------------*-- Comp -*-===#
#
# 1D: 初始化方程右侧有位置信息 - AffineToSCF 测试
# 验证所有 affine.for 被正确降级为 scf.for
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true})" | FileCheck %s

# ===== 确保没有 affine.for =====
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 初始化循环：遍历 x，值为 x =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}101{{.*}} step {{.*}}
# CHECK: arith.index_cast {{.*}} : index to i64
# CHECK: arith.sitofp {{.*}} : i64 to f64
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 边界条件循环1：u(0,t) =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 边界条件循环2：u(100,t) =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主迭代循环：遍历 t =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}50{{.*}} step {{.*}}

# ===== 内层迭代循环：遍历 x =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}101{{.*}} step {{.*}}
# CHECK: memref.load {{.*}} : memref<2x101xf64>
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主循环内的边界条件循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: return

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = x;
    u(0,t) = 0;
    u(100,t) = 0;
    u(x,t+1) = u(x,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}