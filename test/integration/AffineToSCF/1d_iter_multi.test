#===-- 1d_iter_multi.test -------------------------------------*-- Comp -*-===#
#
# 1D: 多个迭代方程 - AffineToSCF 测试
# 验证所有 affine.for 被正确降级为 scf.for
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true})" | FileCheck %s

# ===== 确保没有 affine.for =====
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x51xf64>

# ===== 初始化循环：遍历 x =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}51{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x51xf64>

# ===== 单点边界条件 =====
# CHECK: memref.store {{.*}} : memref<2x51xf64>
# CHECK: memref.store {{.*}} : memref<2x51xf64>

# ===== 主迭代循环：遍历 t =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}101{{.*}} step {{.*}}

# ===== 内层迭代循环：遍历 x (1 to 50)，多个 sample =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}50{{.*}} step {{.*}}
# CHECK: memref.load {{.*}} : memref<2x51xf64>
# CHECK: memref.load {{.*}} : memref<2x51xf64>
# CHECK: memref.load {{.*}} : memref<2x51xf64>
# CHECK: arith.addf
# CHECK: arith.subf
# CHECK: arith.addf
# CHECK: memref.store {{.*}} : memref<2x51xf64>

# ===== 主循环内的边界条件 =====
# CHECK: memref.store {{.*}} : memref<2x51xf64>
# CHECK: memref.store {{.*}} : memref<2x51xf64>

# CHECK: return

declarations {
    x[0,50,51];
    t[0,100,101];
}

equations {
    u(x,0) = 0;
    u(0,t) = 100;
    u(50,t) = 0;
    diff(u(x,t),x,2) = (u(x-1,t)+u(x+1,t)-2*u(x,t))/delta(x,2);
    u(x,t+1) = u(x,t) + diff(u(x,t),x,2);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}
