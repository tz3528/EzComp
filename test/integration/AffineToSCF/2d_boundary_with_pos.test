#===-- 2d_boundary_with_pos.test ------------------------------*-- Comp -*-===#
#
# 2D: 边界方程右侧有位置信息 - AffineToSCF 测试
# u(0,y,t) = y → 边界条件依赖位置
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x11x11xf64>

# ===== 初始化循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 边界条件循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: arith.sitofp {{.*}} : i64 to f64
# CHECK: arith.divf
# CHECK: arith.mulf
# CHECK: arith.addf
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 时间迭代循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = y;
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    u(x,y,t+1) = u(x,y,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}
