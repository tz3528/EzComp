#===-- 2d_boundary_with_time.test -----------------------------*-- Comp -*-===#
#
# 2D: 边界方程右侧有时间信息 - AffineToSCF 测试
# 验证 sin 函数正确降级为 math.sin
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true})" | FileCheck %s

# ===== 确保没有 affine.for =====
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 初始化循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 边界条件循环：u(0,y,t) = sin(t) =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: math.sin {{.*}} : f64
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 主迭代循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}10{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 主循环内的边界条件循环（包含 sin(t) 计算）=====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: math.sin {{.*}} : f64
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: return

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = sin(t);
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    u(x,y,t+1) = u(x,y,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}