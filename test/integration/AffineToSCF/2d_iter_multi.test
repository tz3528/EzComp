#===-- 2d_iter_multi.test -------------------------------------*-- Comp -*-===#
#
# 2D: 多个迭代方程 - AffineToSCF 测试
# diff(u,x,2) = ... 和 u(x,y,t+1) = u(x,y,t) + diff(u,x,2)
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x11x11xf64>

# ===== 初始化循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 时间迭代循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}

# ===== 空间更新循环 =====
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}10{{.*}} step {{.*}}
# CHECK: scf.for {{.*}} = {{.*}} to {{.*}}11{{.*}} step {{.*}}

# ===== 验证多个 memref.load =====
# CHECK-DAG: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK-DAG: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK-DAG: memref.load {{.*}} : memref<2x11x11xf64>

# ===== 算术运算 =====
# CHECK: arith.addf
# CHECK: arith.mulf
# CHECK: arith.subf

# ===== 存储 =====
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = 0;
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    diff(u(x,y,t),x,2) = (u(x-1,y,t)+u(x+1,y,t)-2*u(x,y,t))/delta(x,2);
    u(x,y,t+1) = u(x,y,t) + diff(u(x,y,t),x,2);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}