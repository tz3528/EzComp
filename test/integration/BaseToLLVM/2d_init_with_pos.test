#===-- 2d_init_with_pos.test ----------------------------------*-- Comp -*-===#
#
# 2D: 初始化方程右侧有位置信息 - BaseToLLVM 测试
# u(x,y,0) = x + y → 验证二维坐标计算和类型转换
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true base-llvm=true})" | FileCheck %s

# ===== 验证 LLVM 函数入口 =====
# CHECK-LABEL: llvm.func @main()

# ===== 验证常量（函数开头）=====
# CHECK: llvm.mlir.constant

# ===== 验证内存分配（malloc）=====
# CHECK: llvm.call @malloc

# ===== 验证类型转换：sitofp =====
# CHECK: llvm.sitofp {{.*}} : i64 to f64

# ===== 验证浮点加法 =====
# CHECK: llvm.fadd

# ===== 验证控制流操作 =====
# CHECK: llvm.br
# CHECK: llvm.cond_br

# ===== 验证比较操作 =====
# CHECK: llvm.icmp "slt"

# ===== 验证内存操作 =====
# CHECK: llvm.load
# CHECK: llvm.store

# ===== 验证返回 =====
# CHECK: llvm.return

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = x + y;
    u(0,y,t) = 0;
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    u(x,y,t+1) = u(x,y,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}
