#===-- 2d_iter_single.test ------------------------------------*-- Comp -*-===#
#
# 2D: 单个迭代方程 - BaseToLLVM 测试
# u(x,y,t+1) = u(x,y,t) → 验证 LLVM IR 结构
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true base-llvm=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证运行时库函数声明 =====
# CHECK-DAG: llvm.func @timer_start
# CHECK-DAG: llvm.func @timer_stop_and_print
# CHECK-DAG: llvm.func @malloc
# CHECK-DAG: llvm.func @dump_result_hdf5

# ===== 验证内存分配 =====
# CHECK: llvm.call @malloc

# ===== 验证循环结构：llvm.cond_br =====
# CHECK: llvm.cond_br

# ===== 验证存储操作 =====
# CHECK: llvm.store

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = 0;
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    u(x,y,t+1) = u(x,y,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}