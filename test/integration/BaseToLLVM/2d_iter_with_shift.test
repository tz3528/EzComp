#===-- 2d_iter_with_shift.test --------------------------------*-- Comp -*-===#
#
# 2D: 迭代方程右侧有位置偏移 - BaseToLLVM 测试
# u(x,y,t+1) = u(x-1,y,t) + u(x+1,y,t) + u(x,y-1,t) + u(x,y+1,t)
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true base-llvm=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证运行时库函数声明 =====
# CHECK-DAG: llvm.func @timer_start
# CHECK-DAG: llvm.func @timer_stop_and_print
# CHECK-DAG: llvm.func @malloc

# ===== 验证内存分配 =====
# CHECK: llvm.call @malloc

# ===== 验证循环结构 =====
# CHECK: llvm.cond_br

# ===== 验证多个加载操作 =====
# CHECK: llvm.load
# CHECK: llvm.load
# CHECK: llvm.load
# CHECK: llvm.load

# ===== 验证加法运算 =====
# CHECK: llvm.fadd
# CHECK: llvm.fadd
# CHECK: llvm.fadd

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = 0;
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    u(x,y,t+1) = u(x-1,y,t) + u(x+1,y,t) + u(x,y-1,t) + u(x,y+1,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}
