#===-- 1d_init_with_pos.test ----------------------------------*-- Comp -*-===#
#
# 1D: 初始化方程右侧有位置信息 - CompToBase 测试
# u(x,0) = x → coord 降级为坐标计算
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x101xf64>

# ===== 初始化循环：包含坐标计算 =====
# CHECK: affine.for {{.*}} = 0 to 101
# CHECK: arith.sitofp
# CHECK: arith.divf
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 时间迭代循环 =====
# CHECK: affine.for {{.*}} = 0 to 51

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = x;
    u(0,t) = 0;
    u(100,t) = 0;
    u(x,t+1) = u(x,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}
