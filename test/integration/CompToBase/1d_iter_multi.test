#===-- 1d_iter_multi.test -------------------------------------*-- Comp -*-===#
#
# 1D: 多个迭代方程 - CompToBase 测试
# diff(u,x,2) = ... 和 u(x,t+1) = u(x,t) + diff(u,x,2)
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x101xf64>

# ===== 时间迭代循环 =====
# CHECK: affine.for {{.*}} = 0 to 51

# ===== 空间更新循环：有偏移跳过边界 =====
# CHECK: affine.for {{.*}} = 1 to 100

# ===== 验证多个 affine.load =====
# CHECK-DAG: affine.load {{.*}} : memref<2x101xf64>
# CHECK-DAG: affine.load {{.*}} : memref<2x101xf64>
# CHECK-DAG: affine.load {{.*}} : memref<2x101xf64>

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = 0;
    u(0,t) = 0;
    u(100,t) = 0;
    diff(u(x,t),x,2) = (u(x-1,t)+u(x+1,t)-2*u(x,t))/delta(x,2);
    u(x,t+1) = u(x,t) + diff(u(x,t),x,2);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}
