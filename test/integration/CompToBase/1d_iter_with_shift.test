#===-- 1d_iter_with_shift.test --------------------------------*-- Comp -*-===#
#
# 1D: 迭代方程右侧有位置偏移 - CompToBase 测试
# u(x,t+1) = u(x-1,t) + u(x+1,t)
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x101xf64>

# ===== 时间迭代循环 =====
# CHECK: affine.for {{.*}} = 0 to 51

# ===== 空间更新循环：有偏移 =====
# CHECK: affine.for {{.*}} = 1 to 100

# ===== 验证多个 affine.load =====
# CHECK-DAG: affine.load {{.*}} : memref<2x101xf64>
# CHECK-DAG: affine.load {{.*}} : memref<2x101xf64>

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = 0;
    u(0,t) = 0;
    u(100,t) = 0;
    u(x,t+1) = u(x-1,t) + u(x+1,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}
