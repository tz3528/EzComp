#===-- 1d_boundary_with_time.test -----------------------------*-- Comp -*-===#
#
# 1D: 边界方程右侧有时间信息 - SCFToCF 测试
# 验证 sin 函数被正确降级为 math.sin，scf.for 被正确降级
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true scf-cf=true})" | FileCheck %s

# ===== 确保没有 scf.for 和 affine.for =====
# CHECK-NOT: scf.for
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x101xf64>

# ===== 初始化循环 =====
# CHECK: cf.br {{.*}}(%c0 : index)
# CHECK: arith.cmpi slt, {{.*}}, %c101 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 单点边界条件 =====
# CHECK: memref.store {{.*}} : memref<2x101xf64>
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主迭代循环 =====
# CHECK: arith.cmpi slt, {{.*}}, %c51 : index
# CHECK: cf.cond_br

# CHECK: arith.cmpi slt, {{.*}}, %c101 : index
# CHECK: cf.cond_br
# CHECK: memref.load {{.*}} : memref<2x101xf64>
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# ===== 主循环内的边界条件（包含 sin）=====
# CHECK: math.sin {{.*}} : f64
# CHECK: memref.store {{.*}} : memref<2x101xf64>
# CHECK: memref.store {{.*}} : memref<2x101xf64>

# CHECK: return

declarations {
    x[0,100,101];
    t[0,50,51];
}

equations {
    u(x,0) = 0;
    u(0,t) = sin(t);
    u(100,t) = 0;
    u(x,t+1) = u(x,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,t)";
    timeVar:"t";
}