#===-- 2d_boundary_with_time.test -----------------------------*-- Comp -*-===#
#
# 2D: 边界方程右侧有时间信息 - SCFToCF 测试
# 验证 sin 函数正确降级为 math.sin，scf.for 被正确降级
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true scf-cf=true})" | FileCheck %s

# ===== 确保没有 scf.for 和 affine.for =====
# CHECK-NOT: scf.for
# CHECK-NOT: affine.for

# CHECK-LABEL: func.func @main()

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x11x11xf64>

# ===== 初始化循环 =====
# CHECK: cf.br {{.*}}(%c0 : index)
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 边界条件循环：u(0,y,t) = sin(t) =====
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: math.sin {{.*}} : f64
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 主迭代循环 =====
# CHECK: arith.cmpi slt, {{.*}}, %c10 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# ===== 主循环内的边界条件循环（包含 sin(t) 计算）=====
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: math.sin {{.*}} : f64
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: arith.cmpi slt, {{.*}}, %c11 : index
# CHECK: cf.cond_br
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

# CHECK: return

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = sin(t);
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    u(x,y,t+1) = u(x,y,t);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}
