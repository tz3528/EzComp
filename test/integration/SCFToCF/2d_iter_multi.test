#===-- 2d_iter_multi.test -------------------------------------*-- Comp -*-===#
#
# 2D: 多个迭代方程 - SCFToCF 测试
# diff(u,x,2) = ... 和 u(x,y,t+1) = u(x,y,t) + diff(u,x,2)
#
#===------------------------------------------------------------------------===#

# RUN: %ezcomp %s --emit=mlir --pass-pipeline="builtin.module(lowering{comp-base=true affine-scf=true scf-cf=true})" | FileCheck %s

# ===== 验证 comp 方言操作已消除 =====
# CHECK-NOT: comp.

# ===== 验证运行时库函数声明 =====
# CHECK-DAG: func.func private @timer_start
# CHECK-DAG: func.func private @timer_stop_and_print

# ===== 验证 memref 分配 =====
# CHECK: memref.alloc() : memref<2x11x11xf64>

# ===== 验证 cf 循环结构 =====
# CHECK: cf.br
# CHECK: cf.cond_br

# ===== 验证加载和存储 =====
# CHECK: memref.load {{.*}} : memref<2x11x11xf64>
# CHECK: memref.store {{.*}} : memref<2x11x11xf64>

declarations {
    x[0,10,11];
    y[0,10,11];
    t[0,10,11];
}

equations {
    u(x,y,0) = 0;
    u(0,y,t) = 0;
    u(10,y,t) = 0;
    u(x,0,t) = 0;
    u(x,10,t) = 0;
    diff(u(x,y,t),x,2) = (u(x-1,y,t)+u(x+1,y,t)-2*u(x,y,t))/delta(x,2);
    u(x,y,t+1) = u(x,y,t) + diff(u(x,y,t),x,2);
}

options {
    mode:"time-pde";
    method:"FDM";
    precision:-6;
    function:"u(x,y,t)";
    timeVar:"t";
}
